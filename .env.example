# =============================================================================
# Vajra.Stream — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real credentials.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM API Keys (used by core/llm_integration.py, backend LLM endpoint)
# ---------------------------------------------------------------------------

# DeepSeek v4 (OpenAI-compatible API)
# Sign up: https://platform.deepseek.com
# Model: deepseek-chat (v4)
# Pricing: ~$0.14/M input, ~$0.28/M output tokens
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Optional: override the default model
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI (GPT-4o, GPT-4o-mini)
# Sign up: https://platform.openai.com
OPENAI_API_KEY=sk-your-openai-key-here
# Optional: custom base URL for OpenAI-compatible endpoints (Together, Groq, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude 3.5 Sonnet, Haiku)
# Sign up: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Local LM Studio (OpenAI-compatible server)
# Download: https://lmstudio.ai
# Default endpoint: http://127.0.0.1:1234
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234

# ---------------------------------------------------------------------------
# TTS API Keys (used by core/enhanced_tts.py)
# ---------------------------------------------------------------------------

# ElevenLabs — premium neural TTS
# Sign up: https://elevenlabs.io
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Azure Cognitive Services Speech
# Sign up: https://azure.microsoft.com/services/cognitive-services/text-to-speech/
AZURE_SPEECH_KEY=your-azure-key-here
AZURE_SPEECH_REGION=westus

# Google Cloud Text-to-Speech
# Requires service account JSON file path
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# OpenAI TTS (uses OPENAI_API_KEY above)
# Can also use DeepSeek TTS endpoint:
# OPENAI_BASE_URL=https://api.deepseek.com

# ---------------------------------------------------------------------------
# Image Generation API Keys (used by backend/core/services/sigil_service.py)
# ---------------------------------------------------------------------------

# OpenAI DALL-E (uses OPENAI_API_KEY above)
# ComfyUI local Stable Diffusion
# COMFYUI_BASE_URL=http://127.0.0.1:8188

# ---------------------------------------------------------------------------
# Z AI GLM (used by ai_integration_project)
# ---------------------------------------------------------------------------

# Z_AI_API_KEY=your-z-ai-key-here

# ---------------------------------------------------------------------------
# Backend Configuration (used by backend/app/config.py)
# ---------------------------------------------------------------------------

# DATABASE_URL=sqlite:///./vajra_stream.db
# SAMPLE_RATE=44100
# CORS_ORIGINS=["http://localhost:3009","http://localhost:5173"]
# HARDWARE_LEVEL=2

# ---------------------------------------------------------------------------
# Usage Tracking (optional — defaults shown)
# ---------------------------------------------------------------------------

# Enable token/cost usage tracking
# LLM_USAGE_TRACKING=true
# Path to usage log (JSONL format)
# LLM_USAGE_LOG_PATH=./logs/llm_usage.jsonl
# Estimated cost per 1M tokens (overrides built-in defaults)
# DEEPSEEK_INPUT_COST_PER_M=0.14
# DEEPSEEK_OUTPUT_COST_PER_M=0.28
# OPENAI_INPUT_COST_PER_M=2.50
# OPENAI_OUTPUT_COST_PER_M=10.00
